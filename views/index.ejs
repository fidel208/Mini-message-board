<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
</head>
<body>
    <h1><%= title %></h1>
    <ul>
       <% messages.forEach((message, index) => { %>
      <li>
        <p><b><%= message.user %></b></p>
        <p><%= message.text %></p>
        <p><i><%= message.added %></i></p>

        <a href="/message/<%= index %>">Open</a>
    </li><% }) %>
</ul>
    <a href="/new">Add new messages</a>
</body>
</html>